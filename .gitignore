# MEWS-FIN .gitignore
# Phase 1: Core specs and scaffold

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/
.pytype/

# Jupyter (explicitly excluded in Phase 1)
.ipynb_checkpoints/
*.ipynb

# Data artifacts (Phase 2+)
data/
*.csv
*.parquet
*.json
!core_specs/*.yaml
!data-ingestion/outputs/datasets/market_prices/v1/.gitkeep

# Logs
*.log
logs/
risk_engine/ml/autoresearch/results.tsv

# Secrets (must never exist)
.env
*.pem
*.key
credentials.*
